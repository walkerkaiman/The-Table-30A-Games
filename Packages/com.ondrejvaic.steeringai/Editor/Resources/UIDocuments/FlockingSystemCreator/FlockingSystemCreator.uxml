<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:TextField picking-mode="Ignore" label="Animal name" name="animal-name-text-field" />
    <ui:TextField picking-mode="Ignore" label="Authoring name" name="authoring-name-text-field" style="display: none;" />
    <ui:VisualElement name="main-tag-picker" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); display: none;" />
    <ui:VisualElement name="main-settings-picker" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); display: none;" />
    <ui:Button text="Create" display-tooltip-when-elided="true" name="create-button" />
</ui:UXML>
